@page "/portfolio"

<PageTitle>Portfolio &mdash; Devon VanNote</PageTitle>

<section class="section-container">
    <h2 class="section-title">Portfolio</h2>

    <div class="gamedev-card">
        <div class="gamedev-header">
            <div>
                <h3 class="gamedev-title">
                    <a href="https://jiraplanningpoker.com/" target="_blank" rel="noopener noreferrer">
                        Jira Planning Poker
                    </a>
                </h3>
                <p class="gamedev-subtitle">Free Planning Poker Tool &mdash; Jira Integration</p>
            </div>
            <a href="https://jiraplanningpoker.com/" target="_blank" rel="noopener noreferrer" class="steam-btn">
                Visit Site &#8599;
            </a>
        </div>

        <p>
            A free, real-time planning poker app built for agile teams. Connects directly to Jira so teams
            can vote on story points without leaving their sprint workflow.
        </p>

        <div class="gamedev-sections">

            <div class="gamedev-section">
                <h4>Jira Integration</h4>
                <p>
                    Connects to Jira via OAuth so teams can pull in issues directly and push story point
                    estimates back to the ticket without any copy-paste.
                </p>
            </div>

            <div class="gamedev-section">
                <h4>Real-Time Voting</h4>
                <p>
                    Rooms are synchronized in real time so every participant sees votes reveal simultaneously,
                    keeping estimation sessions fast and honest.
                </p>
            </div>

            <div class="gamedev-section">
                <h4>No Account Required</h4>
                <p>
                    Participants can join a session instantly without creating an account, lowering friction
                    for the whole team.
                </p>
            </div>

        </div>

        <div class="gamedev-tags">
            <span class="skill-badge">C#</span>
            <span class="skill-badge">.NET</span>
            <span class="skill-badge">Blazor</span>
            <span class="skill-badge">SignalR</span>
            <span class="skill-badge secondary">Jira</span>
            <span class="skill-badge secondary">OAuth</span>
        </div>
    </div>

</section>
